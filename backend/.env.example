# Configuración del backend. Copiar a .env y completar. NUNCA commitear .env.
# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/redvidar_ingest?schema=public"

# Secreto para firmar JWT
JWT_SECRET="cambia-este-secreto-en-produccion"

# Credencial de Red Vidar — SOLO aquí, nunca en frontend, código, logs ni respuestas (Principio V, FR-030)
RED_VIDAR_API_KEY="rv_pc_live_xxxxxxxxxxxxxxxx"
RED_VIDAR_BASE_URL="https://api.redvidar.example/v1"

# Límite de tamaño de subida en bytes (default ~10 MB)
MAX_UPLOAD_BYTES=10485760

# Puerto del servidor HTTP
PORT=3001

# Prefijo propio de la plataforma para claves de API de integradores (NUNCA rv_pc_live_)
PLATFORM_API_KEY_PREFIX="emp_live_"
